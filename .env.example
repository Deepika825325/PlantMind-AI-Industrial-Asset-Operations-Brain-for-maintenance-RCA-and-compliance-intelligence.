# ============================================================
# PlantMind Nexus - Docker Development Environment
# ============================================================
# Copy this file to .env for local Docker Compose usage.
# Never use these example credentials in production.

COMPOSE_PROJECT_NAME=plantmind-nexus
APP_ENV=development
TZ=Asia/Kolkata

# ============================================================
# PlantMind API
# ============================================================

API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
LOG_LEVEL=INFO

# Keep the existing JSON demo repositories active.
PLANTMIND_DATA_BACKEND=json

# Browser origins permitted to call the API.
CORS_ORIGINS=http://localhost:3000

# ============================================================
# Authentication
# ============================================================

# Keep auth optional during Day 8 so the existing demo remains open.
AUTH_REQUIRED=false

# Development-only JWT settings. Replace in production.
JWT_SECRET_KEY=plantmind-development-secret-change-me
JWT_ISSUER=plantmind-api
JWT_ACCESS_TOKEN_MINUTES=30
JWT_REFRESH_TOKEN_DAYS=7

# Seeded development user.
DEMO_AUTH_EMAIL=admin@plantmind.local
DEMO_AUTH_PASSWORD=plantmind-admin
DEMO_AUTH_FULL_NAME=PlantMind Administrator
DEMO_AUTH_ROLE=administrator

# ============================================================
# PlantMind Web
# ============================================================

WEB_HOST=0.0.0.0
WEB_PORT=3000

# This URL is used by the browser, so it must use localhost
# rather than the internal Docker service name.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
API_INTERNAL_BASE_URL=http://api:8000

# ============================================================
# PostgreSQL
# ============================================================

POSTGRES_DB=plantmind
POSTGRES_USER=plantmind
POSTGRES_PASSWORD=plantmind_dev_password
POSTGRES_PORT=15432

# Docker services reach PostgreSQL through the service name:
# postgres
DATABASE_URL=postgresql+psycopg://plantmind:plantmind_dev_password@postgres:5432/plantmind

# ============================================================
# Redis
# ============================================================

REDIS_PORT=16379
REDIS_URL=redis://redis:6379/0

# ============================================================
# Qdrant Vector Database
# ============================================================

QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=plantmind_documents

# ============================================================
# MinIO Object Storage
# ============================================================

MINIO_API_PORT=19000
MINIO_CONSOLE_PORT=19001
MINIO_ROOT_USER=plantmind
MINIO_ROOT_PASSWORD=plantmind_dev_password
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=plantmind
MINIO_SECURE=false
