# Python cache
__pycache__/
*/__pycache__/
*.py[cod]
*$py.class

# Virtual environment
.venv/
venv/
env/
ENV/

# Environment variables
.env
.env.*
!.env.example

# Python build files
build/
dist/
*.egg-info/
.eggs/
*.egg

# Test/cache folders
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Jupyter
.ipynb_checkpoints/

# FastAPI/Uvicorn logs
*.log

# OS files
.DS_Store
Thumbs.db

# VS Code
.vscode/
!.vscode/settings.json

# Node / Frontend
node_modules/
.next/
out/
dist/
.angular/
coverage/

# Docker/local runtime
*.pid
*.sock

# Large external public datasets
# Keep README files, ignore downloaded heavy dataset files
data/raw/public_sources/**/*.csv
data/raw/public_sources/**/*.txt
data/raw/public_sources/**/*.zip
data/raw/public_sources/**/*.xlsx

# Allow README reference files inside public_sources
!data/raw/public_sources/**/README.md
!data/raw/public_sources/**/README.txt
!data/raw/public_sources/**/README_*.md

# Optional local temp files
tmp/
temp/
.cache/